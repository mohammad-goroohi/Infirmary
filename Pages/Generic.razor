@page "/Generic/{Id}"
@using System.Dynamic
@layout MainLayout
@inject GenericService _genericService
@inject ToastService _toastService

<DataGrid Config="DataGridConfig" />

@code {
    [Parameter]
    public string? Id { get; set; }
    public DataGridConfig DataGridConfig { get; set; }


    protected override async Task OnInitializedAsync()
    {
        int serviceId = Convert.ToInt32(Id);
        var service = _genericService.Read(serviceId);


        DataGridConfig = new DataGridConfig();
        DataGridConfig.Title = service.DataGridTitle;
        DataGridConfig.GroupActions = new List<DataGridRowActionGroup>
        {
            new DataGridRowActionGroup
            {
                Width = "200px",
                Actions = new List<DataGridRowAction>
                {
                    new DataGridRowAction
                    {
                        ButtonClass = ButtonsClass.btn_primary,
                        IconClass=IconsClass.fa_pen_to_square,
                        OnClick = (rowitem) =>
                        {

                        }
                    }
                }
            }
        };

        DataGridConfig.Columns = GenerateDataGridColumn(service);
        DataGridConfig.LoadDataAsync = () =>
        {
            return Task.FromResult(_genericService.Read(service.ServiceName).Cast<dynamic>().ToList());
        };
        DataGridConfig.DeleteRowButtonDataGridConfig.OnOpenModal = (row) =>
        {
            return new ConfirmModal
                {
                    Title = "هشدار",
                    Content = "ایا از حذف این سطر مطمئن هستید؟",
                    OnConfirm = () =>
{
        _genericService.Delete(service.ServiceName, Convert.ToInt32(row["Id"]));
    }
                };
        };
        DataGridConfig.EditRowButtonDataGridConfig.OnOpenModal = (row) =>
        {
            return new InputModal
                {
                    Title = "ویرایش کاربر",
                    ColumnCount = 2,
                    Size = ModalSize.modal_xl,
                    OnSubmit = (form) =>
                    {
                                int Id = form["Id"].ToInt32();

                                var baseEntity = _genericService.Read(service.ServiceName, Id);
                                foreach (var item in service.Fields)
                                {
                                    baseEntity.GetType().GetProperty(item.Key.Name).SetValue(baseEntity, form[item.Key.Name]);
                                }
                                return true;
                            },
                    Fields = GenerateEditModalFields(service,row)
                };
        };
        DataGridConfig.NewRowButtonDataGridConfig = new NewRowButtonDataGridConfig
            {
                ButtonTitle = service.DataGridNewRowButtonTitle,
                IsShow = true,
                OnOpenModal = () =>
                {
                    return new InputModal
                    {
                        Title = service.DataGridNewRowButtonTitle,
                        ColumnCount = 2,
                        Size = ModalSize.modal_xl,
                        Fields = service.Fields.Select(f => new ItemField
                        {
                            PropertyName = f.Key.Name,
                            Title = f.Key.Title
                        }).ToList(),
                        OnSubmit = (form) =>
                        {
                            var dict = new Dictionary<string, Type>();
                            foreach (var field in service.Fields)
                            {
                                dict.Add(field.Key.Name, typeof(string));
                            }
                            var baseEntity = (BaseEntity)BaseEntity.CreateDynamicEntity(service.ServiceName, dict);
                            foreach (var item in service.Fields)
                            {
                                baseEntity.GetType().GetProperty(item.Key.Name).SetValue(baseEntity, form[item.Key.Name]);
                            }
                            baseEntity.Id = _genericService.Create(service.ServiceName, baseEntity);

                            return true;
                        }
                    };
                }
            };

    }

    private List<DataGridColumn> GenerateDataGridColumn(Models.Generic service)
    {
        var cols = new List<DataGridColumn>();
        cols.Add(new DataGridColumn
            {
                PropertyName = "Id",
                Title = "شناسه"
            });
        cols.AddRange(service.Fields.Select(f => new DataGridColumn
            {
                PropertyName = f.Key.Name,
                Title = f.Key.Title
            }));
            return cols;
    }    
    private List<ItemField> GenerateEditModalFields(Models.Generic service, Dictionary<string, string> row)
    {
        var cols = new List<ItemField>();
        cols.Add(new ItemField
            {
                PropertyName = "Id",
                Title = "شناسه",
                Value = row["Id"],
                ValuType = ModelEditorValueType.Readonly
            });
        cols.AddRange(service.Fields.Select(f => new ItemField
            {
                PropertyName = f.Key.Name,
                Title = f.Key.Title,
                Value = row[f.Key.Name],
            }));
            return cols;
    }
}
